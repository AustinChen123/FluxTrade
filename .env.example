POSTGRES_USER=fluxtrade
POSTGRES_PASSWORD=fluxtrade_password
POSTGRES_DB=fluxtrade
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379
# Redis auth (leave empty for no password in local dev)
REDIS_PASSWORD=

HOT_STRATEGIES_PATH=/app/strategies_hot

# Exchange Config (Optional for Mock Mode)
EXCHANGE_ID=binance
EXCHANGE_API_KEY=
EXCHANGE_SECRET=
EXCHANGE_TESTNET=true

# Dashboard auth (leave empty to disable login)
DASHBOARD_PASSWORD=

# Risk Management Configuration
RISK_MAX_SINGLE_ORDER_NOTIONAL_PCT=0.05          # Decimal fraction: 0.05 = 5% of NAV per order
RISK_DAILY_LOSS_CIRCUIT_BREAKER_PCT=0.05        # Decimal fraction: 0.05 = 5% daily NAV loss
RISK_MAX_ORDERS_PER_MINUTE=10                   # Max accepted entry orders per strategy per rolling minute
RISK_MAX_PRICE_DEVIATION_FROM_MID_PCT=0.03      # Decimal fraction: 0.03 = 3% from bid/ask mid
RISK_MAX_POSITION_NOTIONAL=100000               # Max projected position notional in USDT
